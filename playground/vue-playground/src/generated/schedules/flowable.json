{
  "title": "Flowable 前端对接 · 21 天学习计划",
  "subtitle": "弹性节奏 · 打卡自测 · 薄弱点次日巩固",
  "totalDays": 21,
  "hoursPerDay": "~1h（可视情况增减）",
  "audience": "frontend",
  "flexible": true,
  "phases": [
    {
      "id": "phase-0",
      "name": "概念期",
      "dayRange": [
        1,
        5
      ],
      "goal": "看懂 BPMN、搞清术语、明确前后端分工"
    },
    {
      "id": "phase-1",
      "name": "接口期",
      "dayRange": [
        6,
        10
      ],
      "goal": "搞懂审批流 API 契约，Mock/Postman 走通"
    },
    {
      "id": "phase-2",
      "name": "实战期",
      "dayRange": [
        11,
        19
      ],
      "goal": "Vue 发起/待办/审批/时间线页面"
    },
    {
      "id": "phase-3",
      "name": "通关期",
      "dayRange": [
        20,
        21
      ],
      "goal": "模拟对接 + 综合自测"
    }
  ],
  "tagLabels": {
    "concept-why": "为什么用流程引擎",
    "bpmn-basic": "BPMN 基础元素",
    "bpmn-gateway": "网关与分支",
    "bpmn-task": "用户任务",
    "terminology": "核心术语",
    "boundary": "前后端职责",
    "business-key": "businessKey",
    "api-overview": "接口全景",
    "api-start": "发起接口",
    "variables": "流程变量",
    "api-todo": "待办接口",
    "api-complete": "审批接口",
    "api-history": "审批历史",
    "api-detail": "详情接口",
    "api-state": "状态映射",
    "api-checklist": "联调清单",
    "vue-setup": "项目骨架",
    "mock": "Mock 数据",
    "vue-start-form": "发起页",
    "vue-todo-list": "待办列表",
    "vue-approve": "审批操作",
    "vue-detail": "详情页",
    "vue-timeline": "时间线",
    "vue-tabs": "Tab 导航",
    "vue-error-states": "边界态",
    "vue-polish": "体验打磨",
    "integration": "模拟对接",
    "final-review": "综合复盘"
  },
  "reinforcementLibrary": {
    "concept-why": {
      "title": "巩固 · 流程引擎价值",
      "duration": "15min",
      "tasks": [
        "不查资料，重写「为什么审批不用 if/else 硬写」三点理由",
        "找一个你经历过的审批场景，口述若用流程引擎有什么好处"
      ]
    },
    "bpmn-basic": {
      "title": "巩固 · BPMN 元素识别",
      "duration": "20min",
      "tasks": [
        "打开 bpmn.io，只拖 4 种元素各一个，口述各自含义",
        "重看 Day 2 笔记，补画一张仅含开始-任务-结束的极简图"
      ],
      "resources": [
        {
          "title": "bpmn.io 在线建模",
          "url": "https://bpmn.io/"
        }
      ]
    },
    "bpmn-gateway": {
      "title": "巩固 · 网关与分支",
      "duration": "20min",
      "tasks": [
        "手绘「同意 / 驳回」两条路径，标出排他网关位置",
        "回答：驳回后流程是结束还是回到提交人？（与后端确认的一般规则）"
      ]
    },
    "bpmn-task": {
      "title": "巩固 · 用户任务",
      "duration": "15min",
      "tasks": [
        "解释：用户任务和「服务任务」对前端有什么区别？",
        "列出待办列表里必须展示的 3 个字段及原因"
      ]
    },
    "terminology": {
      "title": "巩固 · 四术语辨析",
      "duration": "15min",
      "tasks": [
        "各用一句话 + 一个例子解释：流程定义、流程实例、用户任务、流程变量",
        "完成一次「术语填空」自测（见当日自测区）"
      ]
    },
    "boundary": {
      "title": "巩固 · 职责边界",
      "duration": "15min",
      "tasks": [
        "列出 3 件「后端主责你不必做」的事",
        "列出 3 件「前端主责」的事"
      ]
    },
    "business-key": {
      "title": "巩固 · businessKey",
      "duration": "15min",
      "tasks": [
        "画图：业务单 id 如何关联流程实例",
        "说明从待办跳详情时应带 taskId 还是 businessKey"
      ]
    },
    "api-overview": {
      "title": "巩固 · 接口全景",
      "duration": "20min",
      "tasks": [
        "不看文档，写出审批流至少 5 个接口及其用途",
        "对照 Day 6 资源查漏补缺"
      ]
    },
    "api-start": {
      "title": "巩固 · 发起接口",
      "duration": "20min",
      "tasks": [
        "列出请假发起应传的字段及哪些可能进流程变量",
        "用 Postman 或 Mock 再模拟一次发起请求"
      ]
    },
    "variables": {
      "title": "巩固 · 流程变量",
      "duration": "15min",
      "tasks": [
        "解释：表单字段 vs 流程变量 vs 业务表字段",
        "举例：days > 3 分支依赖哪个变量、谁负责在发起时传入"
      ]
    },
    "api-todo": {
      "title": "巩固 · 待办接口",
      "duration": "20min",
      "tasks": [
        "说明待办为空时前端 vs 后端各查什么",
        "确认列表项里 taskId 字段名（与后端对齐话术写一条）"
      ]
    },
    "api-complete": {
      "title": "巩固 · 审批接口",
      "duration": "20min",
      "tasks": [
        "写出同意/驳回请求体差异（字段名以你们 Mock 为准）",
        "复述：taskId 过期或被他人处理时前端如何提示"
      ]
    },
    "api-history": {
      "title": "巩固 · 历史接口",
      "duration": "20min",
      "tasks": [
        "画出时间线 UI 需要的最小字段列表",
        "对比：历史接口 vs 详情接口是否可合并请求"
      ]
    },
    "api-detail": {
      "title": "巩固 · 详情接口",
      "duration": "15min",
      "tasks": [
        "列出详情页三个区块：业务信息 / 流程状态 / 操作按钮",
        "说明审批后应用刷新还是乐观更新"
      ]
    },
    "api-state": {
      "title": "巩固 · 状态映射",
      "duration": "20min",
      "tasks": [
        "重做「业务状态 ↔ 展示文案 ↔ 按钮显隐」对照表",
        "专门练驳回后的状态与可编辑规则"
      ]
    },
    "api-checklist": {
      "title": "巩固 · 联调清单",
      "duration": "15min",
      "tasks": [
        "重读 notes/api-contract-checklist.md（若已创建则对照）",
        "准备 5 个联调时要问后端的问题"
      ]
    },
    "vue-setup": {
      "title": "巩固 · 项目骨架",
      "duration": "20min",
      "tasks": [
        "确认路由、类型定义、api 模块分层清晰",
        "检查 Mock 数据是否覆盖主流程"
      ]
    },
    "mock": {
      "title": "巩固 · Mock 走通",
      "duration": "20min",
      "tasks": [
        "在 Network 面板确认发起→待办→审批→历史 四条请求顺序"
      ]
    },
    "vue-start-form": {
      "title": "巩固 · 发起页",
      "duration": "25min",
      "tasks": [
        "补全表单校验与 loading/error 态",
        "自测空提交、网络失败两种边界"
      ]
    },
    "vue-todo-list": {
      "title": "巩固 · 待办列表",
      "duration": "25min",
      "tasks": [
        "补空状态文案与刷新机制",
        "确认点击行能带上正确 taskId 进入审批"
      ]
    },
    "vue-approve": {
      "title": "巩固 · 审批操作",
      "duration": "25min",
      "tasks": [
        "驳回时意见是否必填？与产品规则对齐并实现",
        "审批成功后列表项消失或状态更新是否正确"
      ]
    },
    "vue-detail": {
      "title": "巩固 · 详情页",
      "duration": "20min",
      "tasks": [
        "业务字段只读展示是否完整",
        "当前节点/状态是否有清晰标识"
      ]
    },
    "vue-timeline": {
      "title": "巩固 · 时间线",
      "duration": "25min",
      "tasks": [
        "按时间倒序/正序与后端约定一致",
        "缺字段时是否有占位而非布局崩溃"
      ]
    },
    "vue-tabs": {
      "title": "巩固 · Tab 切换",
      "duration": "20min",
      "tasks": [
        "待办/已办/我发起的数据源是否分离清晰",
        "切换 Tab 是否重复请求、有无缓存策略"
      ]
    },
    "vue-error-states": {
      "title": "巩固 · 边界态",
      "duration": "20min",
      "tasks": [
        "逐条过：无权限、任务已处理、网络错误、空列表"
      ]
    },
    "vue-polish": {
      "title": "巩固 · 体验",
      "duration": "20min",
      "tasks": [
        "走一遍 UI Pass：间距、按钮层级、loading 一致性"
      ]
    },
    "integration": {
      "title": "巩固 · 端到端",
      "duration": "30min",
      "tasks": [
        "不看笔记完整演示一遍主流程",
        "记录仍不确定的一个联调点并写成问题"
      ]
    },
    "final-review": {
      "title": "巩固 · 综合",
      "duration": "30min",
      "tasks": [
        "重做错题/标「不熟」的自测项",
        "更新个人「审批流对接速查」5 条"
      ]
    }
  },
